# File: .env.example
# Telegram Bot Configuration
MANGA_BOT_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Engine Configuration (Google Gemini)
MANGA_BOT_AI_PROVIDER=gemini
MANGA_BOT_AI_API_KEY=your_google_gemini_api_key_here
MANGA_BOT_AI_TIMEOUT_SECONDS=60.0

# Queue & Job Manager Configuration
MANGA_BOT_QUEUE_MAX_SIZE=100
MANGA_BOT_POST_JOB_DELAY_SECONDS=10

# Telegram Rendering Configuration
MANGA_BOT_TELEGRAM_TEXT_LIMIT=4096
MANGA_BOT_TELEGRAM_SEND_DELAY_SECONDS=0.3

# Pagination Configuration
MANGA_BOT_MESSAGE_MAX_LENGTH=3500

# Logging Configuration
MANGA_BOT_LOG_LEVEL=INFO